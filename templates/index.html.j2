<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Registry - Awesome List</title>
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
  <meta name="description" content="A curated list of my public repositories">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0">

  <link rel="stylesheet" href="//cdn.jsdelivr.net/npm/docsify-darklight-theme@3.2.0/dist/style.min.css" title="docsify-darklight-theme" type="text/css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@m234/nerd-fonts@3.4.0/css/0xproto.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <style>
    :root {
      --docsify-darklight-theme-accent: #32CD32 !important;
    }
    
    body {
      font-family: '0xProto Nerd Font', monospace !important;
    }

    body.dark {
      --docsify-darklight-theme-background: #121212 !important;
      --docsify-darklight-theme-textColor: #32CD32 !important;
      --docsify-darklight-theme-codeBackgroundColor: #0a0a0a !important;
      --docsify-darklight-theme-codeTextColor: #32CD32 !important;
    }

    body.light {
      --docsify-darklight-theme-background: #ffffff !important;
      --docsify-darklight-theme-textColor: #000000 !important;
    }

    .markdown-section code {
      font-family: '0xProto Nerd Font', monospace !important;
      background: #0a0a0a !important;
      color: #32CD32 !important;
      border: 1px solid #1f3a1f !important;
      box-shadow: inset 1px 1px 0 rgba(0, 0, 0, 0.6), inset -1px -1px 0 rgba(50, 205, 50, 0.08) !important;
      padding: 1px 6px !important;
      border-radius: 0 !important;
    }

    .markdown-section a code,
    .markdown-section a:hover code {
      background: transparent !important;
      border-color: transparent !important;
      box-shadow: none !important;
      padding: 0 !important;
    }

    .markdown-section a code {
      color: #32CD32 !important;
      transition: color 120ms linear !important;
    }

    .markdown-section a:hover code {
      color: #7CFF7C !important;
    }

    .markdown-section repo-tag {
      display: inline-block;
      font-family: '0xProto Nerd Font', monospace;
      font-size: 0.85em;
      background: #0a0a0a;
      color: #32CD32;
      border: 1px solid #1f3a1f;
      box-shadow: inset 1px 1px 0 rgba(0, 0, 0, 0.6), inset -1px -1px 0 rgba(50, 205, 50, 0.08);
      padding: 1px 6px;
      margin-right: 4px;
      line-height: 1.4;
    }

    .markdown-section table tr:nth-child(odd) {
      background-color: #121212 !important;
    }
    .markdown-section table tr:nth-child(even) {
      background-color: #1a1a1a !important;
    }

    .markdown-section table thead tr {
      background-color: #1a1a1a !important;
      border-bottom: 2px solid #32CD32;
    }

    .markdown-section table td, .markdown-section table th {
      border: 1px solid #222 !important;
      padding: 10px;
    }

    .markdown-section table tbody td:nth-child(2) {
      color: #d4d4d4 !important;
      font-style: italic !important;
    }

    .markdown-section .github-only {
      display: none !important;
    }

    .category-icon {
      margin-right: 10px;
      width: 1.2em;
      text-align: center;
    }

    .terminal-search-container {
      box-sizing: border-box;
      max-width: 800px;
      margin: 30px auto 20px;
      padding: 0 15px;
      position: relative;
    }
    .terminal-search {
      background: #121212;
      border: 1px solid #32CD32;
      padding: 10px;
      display: flex;
      align-items: center;
      font-family: '0xProto Nerd Font', monospace;
    }
    .terminal-prompt {
      color: #32CD32;
      margin-right: 10px;
      font-weight: bold;
    }
    .terminal-search input {
      background: transparent;
      border: none;
      color: #32CD32;
      outline: none;
      flex-grow: 1;
      font-family: '0xProto Nerd Font', monospace;
      font-size: 16px;
    }
    .terminal-cursor {
      color: #32CD32;
      animation: blink 1s step-end infinite;
      margin-left: 5px;
    }
    @keyframes blink {
      from, to { opacity: 1; }
      50% { opacity: 0; }
    }
    .search-results-container {
      background: #1a1a1a;
      border: 1px solid #32CD32;
      border-top: none;
      max-height: 300px;
      overflow-y: auto;
      display: none;
      position: absolute;
      left: 15px;
      right: 15px;
      box-sizing: border-box;
      z-index: 100;
    }
    .search-results-container.active {
      display: block;
    }
    .search-result-item {
      padding: 8px 12px;
      border-bottom: 1px solid #222;
      cursor: pointer;
    }
    .search-result-item:hover, .search-result-item.selected {
      background: #32CD32;
      color: #121212;
    }
    .search-result-item .repo-name {
      font-weight: bold;
    }
    .search-result-item .repo-desc {
      font-size: 0.8em;
      opacity: 0.8;
      display: block;
    }
  </style>
</head>
<body>
  <div class="terminal-search-container">
    <div class="terminal-search">
      <span class="terminal-prompt">></span>
      <input type="text" id="fuzzy-search" placeholder="search_projects..." autocomplete="off">
      <span class="terminal-cursor">_</span>
    </div>
    <div id="search-results" class="search-results-container"></div>
  </div>
  <div id="app"></div>
  <script src="https://cdn.jsdelivr.net/npm/fuse.js/dist/fuse.js"></script>
  <script>
    const allRepos = {{ repos_json | safe }};
    
    window.$docsify = {
      name: 'Registry',
      repo: 'https://github.com/k0pernikus/registry',
      loadSidebar: false,
      subMaxLevel: 2,
      search: false,
      darklightTheme: {
        defaultTheme: 'dark',
        siteFont: "0xProto Nerd Font",
        codeFontFamily: '0xProto Nerd Font, monospace',
        bodyFontSize: '16px',
        dark: {
          accent: '#32CD32',
          background: '#121212',
          textColor: '#32CD32',
        },
        light: {
          accent: '#32CD32',
          background: '#ffffff',
          textColor: '#000000',
        }
      },
      plugins: [
        function(hook, vm) {
          hook.doneEach(function() {
            const searchInput = document.getElementById('fuzzy-search');
            const resultsContainer = document.getElementById('search-results');
            if (!searchInput || !resultsContainer) {
              return;
            }

            const fuse = new Fuse(allRepos, {
              keys: ['name', 'description', 'url'],
              threshold: 0.4
            });

            let selectedIndex = -1;
            let results = [];

            function renderResults(query) {
              if (query.length < 2) {
                resultsContainer.classList.remove('active');
                results = [];
                selectedIndex = -1;
                return;
              }
              results = fuse.search(query);
              selectedIndex = -1;
              if (results.length === 0) {
                resultsContainer.classList.remove('active');
                return;
              }
              resultsContainer.innerHTML = results.slice(0, 10).map((result, index) => `
                <div class="search-result-item" data-url="${result.item.url}" data-index="${index}">
                  <span class="repo-name">${result.item.name}</span>
                  <span class="repo-desc">${result.item.description || ''}</span>
                </div>
              `).join('');
              resultsContainer.classList.add('active');
            }

            function updateSelection(items) {
              items.forEach((item, index) => {
                const selected = index === selectedIndex;
                item.classList.toggle('selected', selected);
                if (selected) {
                  item.scrollIntoView({ block: 'nearest' });
                }
              });
            }

            function openSelectedOrFirst(items) {
              if (selectedIndex >= 0) {
                window.open(items[selectedIndex].dataset.url, '_blank');
                return;
              }
              if (results.length > 0) {
                window.open(results[0].item.url, '_blank');
              }
            }

            const keyHandlers = {
              ArrowDown: (e, items) => {
                selectedIndex = (selectedIndex + 1) % items.length;
                updateSelection(items);
                e.preventDefault();
              },
              ArrowUp: (e, items) => {
                selectedIndex = (selectedIndex - 1 + items.length) % items.length;
                updateSelection(items);
                e.preventDefault();
              },
              Enter: (_e, items) => {
                openSelectedOrFirst(items);
              },
            };

            searchInput.addEventListener('input', (e) => {
              renderResults(e.target.value);
            });

            searchInput.addEventListener('keydown', (e) => {
              const handler = keyHandlers[e.key];
              if (!handler) {
                return;
              }
              const items = resultsContainer.querySelectorAll('.search-result-item');
              handler(e, items);
            });

            resultsContainer.addEventListener('click', (e) => {
              const item = e.target.closest('.search-result-item');
              if (!item) {
                return;
              }
              window.open(item.dataset.url, '_blank');
            });

            document.addEventListener('click', (e) => {
              if (e.target.closest('.terminal-search-container')) {
                return;
              }
              resultsContainer.classList.remove('active');
            });
          });
        }
      ]
    }
  </script>
  <script src="//cdn.jsdelivr.net/npm/docsify@4"></script>
  <script src="//cdn.jsdelivr.net/npm/docsify/lib/plugins/search.min.js"></script>
  <script src="//cdn.jsdelivr.net/npm/docsify-copy-code@2"></script>
  <script src="//cdn.jsdelivr.net/npm/docsify-darklight-theme@3.2.0/dist/index.min.js"></script>
</body>
</html>
